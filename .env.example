# Chapter comments — Giscus (https://giscus.app/), backed by GitHub Discussions.
# Run through giscus.app once with your repo to obtain the four values below,
# then copy this file to .env.local and fill them in. If any is missing,
# the Discussion section at the end of each chapter is hidden gracefully.
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY=Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxx

# Internal design-system reference page (/internal/showcase). Default: hidden.
# NEXT_PUBLIC_INTERNAL=1

# Canonical public URL used by RSS and metadata. Default: https://kimi.read.wiki
# NEXT_PUBLIC_SITE_URL=https://kimi.read.wiki

# ── Analytics / Stats ──
# Analytics dashboard initial/bootstrap secret.
# Required in production. Use a long random value; it becomes the initial password seed.
# ANALYTICS_SECRET=<32+ random string>

# Durable analytics database. Recommended for serverless production.
# Local dev falls back to ./data/analytics.db when DATABASE_URL is empty. The
# Aliyun single-server deployment keeps that directory under shared/data, so
# local SQLite is persistent there; see docs/DEPLOYMENT_ALIYUN.md.
# Turso/libsql examples:
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=<turso auth token>
# MySQL / MariaDB example (credentials live in the URL — percent-encode special
# characters in the password; DATABASE_AUTH_TOKEN is NOT used with mysql://):
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/analytics

# Scheduled rollup + raw-event pruning. Vercel uses vercel.json; the Aliyun
# deployment uses ops/analytics-rollup.sh from BaoTa's scheduler. Both
# authenticate with CRON_SECRET. Without it, rollup/prune only run when
# triggered manually from the dashboard.
# CRON_SECRET=<32+ random string>

# Raw-events retention in days (rolled-up daily counts are kept regardless).
# Default 90. Prune runs as part of the scheduled rollup above.
# ANALYTICS_RETENTION_DAYS=90

# ── WeChat Mini Program ──
# /api/mp/v1/qrcode generates Mini Program codes via wxacode.getUnlimited
# (mp.weixin.qq.com → 开发管理 → 开发设置). Without both values the endpoint
# answers 503 and the Mini Program falls back to its bundled official code.
# Never commit real values.
# WECHAT_MP_APPID=<mini program appid>
# WECHAT_MP_SECRET=<mini program secret>
